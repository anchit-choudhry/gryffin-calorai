# Copy this file to .env and fill in values before running docker compose.
# .env is gitignored - never commit real secrets.

# JWT signing secret - must be at least 256 bits (32+ chars), random string
JWT_SECRET=change-this-in-production-minimum-256-bits-long

# OAuth2 client IDs (leave blank if not using that provider)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:5173
