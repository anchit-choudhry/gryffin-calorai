# Copy this file to .env and fill in values before running docker compose.
# .env is gitignored - never commit real secrets.

# PostgreSQL database credentials
POSTGRES_DB=gcalorai
POSTGRES_USER=gcalorai
POSTGRES_PASSWORD=

# JWT signing secret - must be at least 256 bits (32+ chars), random string
# Generate with: openssl rand -hex 32
JWT_SECRET=

# OAuth2 client IDs (leave blank if not using that provider)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
APPLE_KEY_ID=
APPLE_TEAM_ID=

# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Enable Swagger UI and OpenAPI docs (disabled in production; set to true for local dev)
SWAGGER_ENABLED=false

# pgAdmin credentials (local dev tool only - not used in production)
PGADMIN_DEFAULT_EMAIL=admin@gryffin-calorai.local
PGADMIN_DEFAULT_PASSWORD=gryffin-calorai-admin

# Valkey connection (only needed when running backend outside Docker; Docker sets these automatically)
VALKEY_HOST=localhost
VALKEY_PORT=6379

# VAPID keys for Web Push notifications (leave blank to disable push)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Must be mailto: or https: identifying the app operator
VAPID_SUBJECT=mailto:admin@localhost
