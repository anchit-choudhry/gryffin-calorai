# REQUIRED BEFORE DEPLOYING: Replace https://YOUR-API-ORIGIN below with your production API
# origin (the value of VITE_API_BASE_URL, e.g. https://api.yourdomain.com).
# Never use http://, localhost, or a wildcard https: in production connect-src.
# vite.config.ts resolves VITE_API_BASE_URL automatically at build time; this file is
# static and served as-is by Netlify/Cloudflare Pages - it must be updated manually.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval' https://accounts.google.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://lh3.googleusercontent.com; font-src 'self'; connect-src 'self' https://corsproxy.io https://accounts.google.com https://huggingface.co https://cdn.jsdelivr.net https://YOUR-API-ORIGIN; worker-src 'self'; frame-src https://accounts.google.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self';
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(self), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Resource-Policy: same-origin

# Service worker must never be stale-cached or the app can't update
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/registerSW.js
  Cache-Control: no-cache, no-store, must-revalidate
