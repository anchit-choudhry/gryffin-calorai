# Guard Makefile - run commands from the repo root.

ROOT := $(shell git rev-parse --show-toplevel)

.PHONY: help
.DEFAULT_GOAL := help

help:
	@echo ""
	@echo "  Run commands from the repo root, not from apps/ios/."
	@echo ""
	@echo "  cd $(ROOT) && make help"
	@echo ""

%:
	@echo ""
	@echo "  Run commands from the repo root, not from apps/ios/."
	@echo ""
	@echo "  cd $(ROOT) && make help"
	@echo ""
