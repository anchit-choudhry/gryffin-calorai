# Disable execution of lifecycle scripts (preinstall, postinstall, etc.) from all dependencies.
# Reduces attack surface by preventing arbitrary code execution during installs; all scripts
# must be manually reviewed and added to pnpm-workspace.yaml allowBuilds if truly needed.
ignore-scripts=true

# Require lockfile to match package.json exactly; fail install if they diverge.
# Enforces deterministic installs and prevents accidental dependency upgrades in CI/local dev,
# ensuring everyone uses the exact pinned versions.
frozen-lockfile=true
