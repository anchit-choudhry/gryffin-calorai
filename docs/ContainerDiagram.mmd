C4Container
  title C4 Container Diagram for Gryffin Calorai (v0.3.0)
  Person(user, "User", "Tracks daily food intake, water, steps, body measurements, recipes, activity logs, fasting sessions, and health progress. Earns gamification achievements.")

  System_Boundary(c1, "Gryffin Calorai Application (Browser)") {
    Container(app, "App Shell", "React 19, TypeScript 6, Vite 8", "Hash-based routing (#dashboard, #recipes, #progress, #settings); dark mode toggle (localStorage + prefers-color-scheme); ErrorBoundary wraps Suspense inside main; MOCK_USER_ID; gzip+brotli compression via vite-plugin-compression2. ProductTourOverlay and KeyboardShortcutsOverlay rendered at app level. OnboardingModal shown on first launch (localStorage flag). Editorial design system: @fontsource-variable (Fraunces, JetBrains Mono, Public Sans), oklch color palette, shadcn/ui primitives.")
    Container(dashboard, "Dashboard Page", "React (React.lazy + Suspense)", "6-section editorial layout: Hero (DashboardHero, calorieGoal from TDEE profile or 2000 kcal fallback), Week in Review (WeeklySummary, StreakCard, StepTracker), Pantry (favorites), Add to Log (FoodLogger, VoiceFoodLogger, BarcodeScanner via nested Suspense, FastingTimer SVG ring widget, ActivityLogger searchable form). Recently Logged scroll chips. Today's Log grouped by meal type (groupLogsByMeal). Activity logs grouped by date with delete-with-undo toast. Dialogs: Edit Log, Barcode Food, Voice Food (shadcn/ui Dialog with focus trap + Esc).")
    Container(recipes, "Recipes Page", "React (React.lazy + Suspense)", "Recipe creation form with dynamic ingredient rows (react-hook-form useFieldArray + zod), saved recipes list with delete.")
    Container(progress, "Progress Page", "React (React.lazy + Suspense)", "7-section layout: 01 Calorie Trend (ComposedChart: stacked bars by meal type + goal line), 02 Macro Breakdown (AreaChart, 7-day only), 03 Meal Distribution (PieChart, 7-day only), 04 Water Intake (AreaChart, useWaterHistoryData), 05 Body Measurements (LineChart: weight, body fat %, waist/chest/hips), 06 Measurement History table, 07 Achievements grid (all 19 achievements, unlocked/locked state). Activity log visualization section. 7/30-day toggle. useReducedMotion for accessibility.")
    Container(settings, "Settings Page", "React (React.lazy + Suspense)", "4-section settings page at #settings. Profile: TdeeProfilePanel (full edit form with live BMR/TDEE/goal preview; unit toggles auto-convert kg/lb, cm/in). Goals: GoalSettings (inline edit for daily water ml and step targets). Data: DataExportPanel (JSON backup export, CSV ZIP export via fflate, JSON backup import with schema validation + confirmation dialog). About: version info + GitHub link.")
    Container(tour, "Product Tour", "React", "ProductTourOverlay renders 8-step guided tour across Dashboard, Recipes, and Progress. CoachmarkCard with step title, body, and nav controls. useSpotlightRect hook computes DOM element bounding rect for spotlight cutout. Spotlight and coachmark entrance/exit animations via motion 12 (spotlightVariants, coachmarkVariants, arrowVariants). Tour state (tourActive, tourStep, tourTotalSteps) in Zustand. Tour completion flag persisted to localStorage.")
    Container(state, "Zustand Store", "Zustand 5", "Single store: dailyLogs, allFoodItems, recipes, favoriteFoods, dailyWaterLogs, bodyMeasurements, dailyStepLogs, unlockedAchievements, tdeeProfile, dailyActivityLogs, allActivityLogs, activeFastingSession, fastingHistory, tourActive, tourStep, tourTotalSteps, init (AppInitState: idle/loading/ready/error), error, waterGoalMl (localStorage), stepGoal (localStorage). ~40 actions: CRUD for food logs, recipes, water logs, body measurements, step logs, achievements; fetchTdeeProfile, saveTdeeProfile; fetchDailyActivityLogs, addActivityLog, deleteActivityLog; fetchFastingSessions, startFasting, endFasting; exportData, importData; startTour, nextTourStep, prevTourStep, endTour, skipTour; completeOnboarding; updateRecipe; setWaterGoalMl, setStepGoal; checkAndUnlockAchievements.")
    Container(hooks, "Custom Hooks", "TypeScript", "useFoodForm, useRecipeForm (useFieldArray), useWaterForm, useStepForm, useBodyForm, useStreaks, useWeeklySummary, useProgressData, useWaterHistoryData, useVoiceCapture (SpeechRecognition), useBarcodeScanner (@zxing/browser, lazy-loaded), useFastingTimer (elapsed via date-fns differenceInSeconds + setInterval; notification permission; start/end persistence), useActivityForm (react-hook-form + zod, MET calorie calc), useOnboarding (multi-step nav, unit conversion, submit), useDataExport (downloadJSON + downloadCSVZip, isExporting state), useDataImport (file parse, schema + version validation, pendingPayload confirmation), useKeyboardShortcuts (global command registry), useSpotlightRect (DOM rect for tour spotlight). All form hooks use react-hook-form 7 + zod (zod/v3) via src/forms/schemas.ts.")
    Container(tdeeEngine, "TDEE Engine", "TypeScript", "src/lib/tdee.ts: mifflinStJeorBMR(age, sex, heightCm, weightKg) -> number. computeTDEE(bmr, activityLevel) -> number using ACTIVITY_LEVEL_FACTORS multipliers. computeCalorieGoal(tdee, goal) -> number with goal offsets (-500 kcal lose, 0 maintain, +300 kcal gain). Activity levels: sedentary(1.2), light(1.375), moderate(1.55), active(1.725), very_active(1.9). src/lib/metTable.ts: ~60 common activities with ACSM MET values. Calorie burn formula: MET * weightKg * (durationMin / 60).")
    Container(types, "Types and Utilities", "TypeScript", "Branded IDs: UserId, FoodItemId, RecipeId, WaterLogId, BodyMeasurementId, UserAchievementId, StepLogId, ActivityLogId, FastingSessionId, ISODate. Domain types: Sex ('male'|'female'), ActivityLevel ('sedentary'|'light'|'moderate'|'active'|'very_active'), GoalType ('lose'|'maintain'|'gain'). Type guards, sanitizers, fuzzyMatchFoodName (Levenshtein). computeStreaks (current + longest). Unit converters: kgToLb, lbToKg, cmToIn, inToCm. Constants: DAILY_WATER_GOAL_ML=2000, DAILY_STEP_GOAL=10000, MEAL_TYPES, FASTING_PRESETS (12:12, 14:10, 16:8, 18:6, OMAD 20h), GOAL_OFFSETS, ACTIVITY_LEVEL_FACTORS. AppInitState discriminated union. src/lib/utils.ts: cn, EDITORIAL_INPUT_CLS, groupLogsByMeal, normalizeHash, mapDbError.")
    Container(achievements, "Achievements Engine", "TypeScript", "src/lib/achievements.ts: 19 ACHIEVEMENTS across 6 categories (streak:4, calorie:3, hydration:3, milestone:4, body:3, recipe:2). evaluateAchievements(params: EvaluationParams, alreadyUnlocked: Set<string>): string[] - checks streak_3/7/14/30, calorie_goal_hit, full_day, calorie_goal_3_days, water_first/goal_hit/streak_3, log_1/10/50/100, body_first/5/10, recipe_first/5. Uses computeStreaks for streak checks.")
    ContainerDb(db, "GryffinCaloraiDB", "IndexedDB via Dexie 4 (schema v13)", "Tables: users (v1), foodItems with isFavorite+mealType (v1/v4/v5), recipes (v1), waterLogs (v6, [userId+dateLogged]), bodyMeasurements (v7, [userId+measuredAt]), userAchievements (v8, [userId+achievementId]), stepLogs (v9, [userId+dateLogged]), tdeeProfiles (v11, userId), activityLogs (v12, [userId+dateLogged]), fastingSessions (v13, [userId+startTime]). BACKUP_VERSION=1. Schema history: v11 tdeeProfiles, v12 activityLogs, v13 fastingSessions. All mutations include userId ownership checks. clearDatabase() blocked in production.")
  }

  System_Ext(securityHeaders, "HTTP Security Headers", "Three-layer delivery: vite.config.ts preview server, public/_headers (Cloudflare/Netlify), index.html meta CSP. Headers: CSP, X-Frame-Options, X-Content-Type-Options, Referrer-Policy, Permissions-Policy, Strict-Transport-Security (HSTS, max-age=31536000), Cross-Origin-Opener-Policy (same-origin), Cross-Origin-Embedder-Policy (require-corp), Cross-Origin-Resource-Policy (same-origin). CSP excluded from dev server to allow Vite Fast Refresh inline script.")
  System_Ext(speechApi, "Web Speech API", "Browser SpeechRecognition / webkitSpeechRecognition for hands-free food entry via useVoiceCapture. Transcript sanitized before reaching store.")
  System_Ext(cameraApi, "Camera / MediaDevices API", "Browser getUserMedia + @zxing/browser (lazy-loaded, deferred vendor-barcode chunk) for barcode scanning. Nutritional data API lookup not yet integrated.")
  System_Ext(notificationApi, "Notification API", "Browser Notification API used by useFastingTimer: requests permission when a fasting session starts; fires a notification when the target fasting duration has elapsed.")
  System_Ext(localStorageFlags, "localStorage (Flags)", "Persists onboarding completion flag (checked by OnboardingModal on first launch), tour completion flag (checked by ProductTourOverlay), dark mode preference, waterGoalMl, stepGoal.")
  Rel(user, app, "Opens app", "HTTPS")
  Rel(app, dashboard, "Renders on #dashboard", "React.lazy + Suspense")
  Rel(app, recipes, "Renders on #recipes", "React.lazy + Suspense")
  Rel(app, progress, "Renders on #progress", "React.lazy + Suspense")
  Rel(app, settings, "Renders on #settings", "React.lazy + Suspense")
  Rel(app, tour, "Renders ProductTourOverlay at app level", "")
  Rel(dashboard, hooks, "Uses", "")
  Rel(recipes, hooks, "Uses", "")
  Rel(progress, hooks, "Uses", "")
  Rel(settings, hooks, "Uses", "")
  Rel(hooks, state, "Reads / dispatches actions", "Zustand subscribe")
  Rel(hooks, types, "Uses branded types and utilities", "")
  Rel(hooks, tdeeEngine, "useOnboarding + useActivityForm call TDEE and MET calculations", "")
  Rel(hooks, notificationApi, "useFastingTimer requests permission and fires notification on target elapsed", "")
  Rel(state, db, "Reads/writes via DB service", "Dexie.js API")
  Rel(state, achievements, "Calls evaluateAchievements on each log mutation", "")
  Rel(state, localStorageFlags, "Reads/writes onboarding flag, tour flag, waterGoalMl, stepGoal", "")
  Rel(achievements, types, "Uses computeStreaks, MEAL_TYPES", "")
  Rel(hooks, speechApi, "Streams transcript", "useVoiceCapture")
  Rel(hooks, cameraApi, "Streams camera frames", "useBarcodeScanner (@zxing, nested Suspense)")
  Rel(app, securityHeaders, "Served with", "CSP, HSTS, COOP, COEP, CORP, X-Frame-Options, Referrer-Policy, Permissions-Policy")
