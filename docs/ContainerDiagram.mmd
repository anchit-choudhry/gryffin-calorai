C4Container
  title C4 Container Diagram for Gryffin Calorai (v0.0.7)
  Person(user, "User", "Tracks daily food intake, water, steps, body measurements, recipes, and health progress. Earns gamification achievements.")

  System_Boundary(c1, "Gryffin Calorai Application (Browser)") {
    Container(app, "App Shell", "React 19, TypeScript 6, Vite 8", "Hash-based routing (#dashboard, #recipes, #progress); dark mode toggle (localStorage + prefers-color-scheme); ErrorBoundary wraps Suspense inside main; MOCK_USER_ID; gzip+brotli compression via vite-plugin-compression2. Editorial design system: @fontsource-variable (Fraunces, JetBrains Mono, Public Sans), oklch color palette, shadcn/ui primitives.")
    Container(dashboard, "Dashboard Page", "React (React.lazy + Suspense)", "6-section editorial layout: Hero (DashboardHero), Week in Review (WeeklySummary, StreakCard, StepTracker), Pantry (favorites), Add to Log (FoodLogger, VoiceFoodLogger, BarcodeScanner via nested Suspense), Recently Logged scroll chips, Today's Log grouped by meal type (groupLogsByMeal). Dialogs: Edit Log, Barcode Food, Voice Food (shadcn/ui Dialog with focus trap + Esc).")
    Container(recipes, "Recipes Page", "React (React.lazy + Suspense)", "Recipe creation form with dynamic ingredient rows (react-hook-form useFieldArray + zod), saved recipes list with delete.")
    Container(progress, "Progress Page", "React (React.lazy + Suspense)", "7-section layout: 01 Calorie Trend (ComposedChart: stacked bars by meal type + goal line), 02 Macro Breakdown (AreaChart, 7-day only), 03 Meal Distribution (PieChart, 7-day only), 04 Water Intake (AreaChart, useWaterHistoryData), 05 Body Measurements (LineChart: weight, body fat %, waist/chest/hips), 06 Measurement History table, 07 Achievements grid (all 18 achievements, unlocked/locked state). 7/30-day toggle. useReducedMotion for accessibility.")
    Container(state, "Zustand Store", "Zustand 5", "Single store: dailyLogs, allFoodItems, recipes, favoriteFoods, dailyWaterLogs, bodyMeasurements, dailyStepLogs, unlockedAchievements, init (AppInitState: idle/loading/ready/error), error, waterGoalMl (localStorage, [250,10000]), stepGoal (localStorage, [1000,100000]). ~25 actions: CRUD for food logs, recipes, water logs, body measurements, step logs, achievements; setWaterGoalMl, setStepGoal, checkAndUnlockAchievements (parallel fetch + evaluateAchievements + batch write + per-unlock toasts).")
    Container(hooks, "Custom Hooks", "TypeScript", "useFoodForm, useRecipeForm (useFieldArray), useWaterForm, useStepForm, useBodyForm, useStreaks, useWeeklySummary, useProgressData (mealTypeData + macroData, 7-day only), useWaterHistoryData (7|30 days, getAllWaterLogs + date bucketing), useVoiceCapture (SpeechRecognition), useBarcodeScanner (@zxing/browser, lazy-loaded). All form hooks use react-hook-form 7 + zod (zod/v3) via src/forms/schemas.ts.")
    Container(types, "Types and Utilities", "TypeScript", "Branded IDs: UserId, FoodItemId, RecipeId, WaterLogId, BodyMeasurementId, UserAchievementId, StepLogId, ISODate. Type guards (isUserId validates [1,128] printable ASCII; isISODate full Date validity), sanitizers, fuzzyMatchFoodName (Levenshtein). computeStreaks (current + longest). Unit converters. Constants: DAILY_WATER_GOAL_ML=2000, DAILY_STEP_GOAL=10000, MEAL_TYPES. AppInitState discriminated union. Utility types: NonEmptyArray<T>, DeepReadonly<T>, AsyncResult<T>. assertDefined<T>. src/lib/utils.ts: cn, EDITORIAL_INPUT_CLS, groupLogsByMeal, normalizeHash, mapDbError.")
    Container(achievements, "Achievements Engine", "TypeScript", "src/lib/achievements.ts: 18 ACHIEVEMENTS across 6 categories (streak, calorie, hydration, milestone, body, recipe). evaluateAchievements(params: EvaluationParams, alreadyUnlocked: Set<string>): string[] - checks streak_3/7/14/30, calorie_goal_hit, full_day, calorie_goal_3_days, water_first/goal_hit/streak_3, log_1/10/50/100, body_first/5/10, recipe_first/5. Uses computeStreaks for streak checks.")
    ContainerDb(db, "GryffinCaloraiDB", "IndexedDB via Dexie 4 (schema v9)", "Tables: users (v1), foodItems with isFavorite+mealType (v1/v4/v5), recipes (v1), waterLogs (v6, [userId+dateLogged]), bodyMeasurements (v7, [userId+measuredAt]), userAchievements (v8, [userId+achievementId], userId, achievementId, unlockedAt), stepLogs (v9, [userId+dateLogged], userId, dateLogged). getAllWaterLogs, getDailyStepLogs, getAllStepLogs, addUserAchievement, getUnlockedAchievements, getUnlockedAchievementIds. All mutations include userId ownership checks. clearDatabase() blocked in production.")
  }

  System_Ext(securityHeaders, "HTTP Security Headers", "Three-layer delivery: vite.config.ts preview server, public/_headers (Cloudflare/Netlify), index.html meta CSP. CSP excluded from dev server to allow Vite Fast Refresh inline script.")
  System_Ext(speechApi, "Web Speech API", "Browser SpeechRecognition / webkitSpeechRecognition for hands-free food entry via useVoiceCapture. Transcript sanitized before reaching store.")
  System_Ext(cameraApi, "Camera / MediaDevices API", "Browser getUserMedia + @zxing/browser (lazy-loaded, deferred vendor-barcode chunk) for barcode scanning. Nutritional data API lookup not yet integrated.")
  Rel(user, app, "Opens app", "HTTPS")
  Rel(app, dashboard, "Renders on #dashboard", "React.lazy + Suspense")
  Rel(app, recipes, "Renders on #recipes", "React.lazy + Suspense")
  Rel(app, progress, "Renders on #progress", "React.lazy + Suspense")
  Rel(dashboard, hooks, "Uses", "")
  Rel(recipes, hooks, "Uses", "")
  Rel(progress, hooks, "Uses", "")
  Rel(hooks, state, "Reads / dispatches actions", "Zustand subscribe")
  Rel(hooks, types, "Uses branded types and utilities", "")
  Rel(state, db, "Reads/writes via DB service", "Dexie.js API")
  Rel(state, achievements, "Calls evaluateAchievements on each log mutation", "")
  Rel(achievements, types, "Uses computeStreaks, MEAL_TYPES", "")
  Rel(hooks, speechApi, "Streams transcript", "useVoiceCapture")
  Rel(hooks, cameraApi, "Streams camera frames", "useBarcodeScanner (@zxing, nested Suspense)")
  Rel(app, securityHeaders, "Served with", "CSP, X-Frame-Options, X-Content-Type-Options, Referrer-Policy, Permissions-Policy")
